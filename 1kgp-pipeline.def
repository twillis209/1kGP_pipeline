# Apptainer / Singularity definition file for 1kGP Snakemake pipeline
#
# Bootstraps directly from the Docker image produced by the Dockerfile,
# or can be built standalone (identical dependency set).
#
# ── Option A: build from the pre-built Docker image ─────────────────────────
#   apptainer build 1kgp-pipeline.sif docker-daemon://1kgp-pipeline:latest
#
# ── Option B: build this .def file directly (pulls from Docker Hub base) ────
#   apptainer build 1kgp-pipeline.sif 1kgp-pipeline.def
#
# ── Run ──────────────────────────────────────────────────────────────────────
#   apptainer exec --bind "$(pwd)":/pipeline --pwd /pipeline \
#       1kgp-pipeline.sif \
#       snakemake --cores <N> <target>
#
# Note: Apptainer automatically binds $HOME and $PWD; use --bind for
# additional paths (e.g., scratch storage).

Bootstrap: docker
From: condaforge/mambaforge:24.3.0-0

%post
    # ── system packages ──────────────────────────────────────────────────
    apt-get update && apt-get install -y --no-install-recommends \
        wget \
        unzip \
        zstd \
        ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

    # ── conda packages (all envs merged into base) ───────────────────────
    # plink/plink2 installed from upstream binaries below (conda is out of date)
    mamba install -y \
        -c conda-forge \
        -c bioconda \
        "snakemake>=9.3" \
        pandas \
        polars \
        ldsc \
        r-base \
        "r-data.table>=1.17" \
        r-ggplot2 \
    && mamba clean -afy

    # ── plink2 and plink1 binaries ────────────────────────────────────────
    wget -q -O /tmp/plink2.zip \
        https://s3.amazonaws.com/plink2-assets/plink2_linux_x86_64_20260307.zip \
    && unzip -j /tmp/plink2.zip plink2 -d /usr/local/bin \
    && chmod +x /usr/local/bin/plink2 \
    && rm /tmp/plink2.zip \
    && wget -q -O /tmp/plink.zip \
        https://s3.amazonaws.com/plink1-assets/plink_linux_x86_64_20250819.zip \
    && unzip -j /tmp/plink.zip plink -d /usr/local/bin \
    && chmod +x /usr/local/bin/plink \
    && rm /tmp/plink.zip

%environment
    # Activate base conda environment
    export PATH="/opt/conda/bin:$PATH"
    export CONDA_DEFAULT_ENV=base

%labels
    org.opencontainers.image.title "1kGP pipeline"
    org.opencontainers.image.description "Snakemake pipeline for 1000 Genomes Project data processing"

%help
    Snakemake pipeline container for 1000 Genomes Project data processing.

    Included tools:
      snakemake >=9.3, plink, plink2, ldsc, R (data.table, ggplot2),
      Python (pandas, polars), wget, zstd

    Example usage:
      apptainer exec --bind "$(pwd)":/pipeline --pwd /pipeline \
          1kgp-pipeline.sif \
          snakemake --cores 8 --rerun-incomplete <target>

    Because all dependencies are bundled, run snakemake WITHOUT --use-conda.
